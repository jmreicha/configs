# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host *
	# Normalized path for 1Password SSH agent — works on both macOS and Linux.
	# On Linux, 1Password creates this socket natively.
	# On macOS, install.sh configure() creates a symlink here pointing to the
	# actual socket at ~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock
	IdentityAgent "~/.1password/agent.sock"
